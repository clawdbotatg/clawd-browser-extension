{
  "manifest_version": 3,
  "name": "Clawd Browser",
  "version": "0.1.0",
  "description": "Lets a local Claude Code session drive this browser through a localhost bridge.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Clawd Browser"
  },
  "background": { "service_worker": "background.js" },
  "permissions": ["tabs", "debugger", "alarms", "storage"],
  "host_permissions": ["<all_urls>"]
}
